# ─── Redis ───────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Sentinel (uncomment for HA setup)
# REDIS_SENTINEL_1=sentinel-1:26379
# REDIS_SENTINEL_2=sentinel-2:26379
# REDIS_SENTINEL_3=sentinel-3:26379
# REDIS_SENTINEL_NAME=mymaster

# ─── Throttle Config ─────────────────────────────────
THROTTLE_GLOBAL_LIMIT=100
THROTTLE_REFILL_RATE=10
THROTTLE_WINDOW_MS=60000
THROTTLE_NODE_COUNT=2
THROTTLE_PEER_URLS=http://server-2:3000
THROTTLE_INTERNAL_KEY=change-me-in-prod
THROTTLE_CIRCUIT_FAILURE_THRESHOLD=3
THROTTLE_CIRCUIT_RECOVERY_PROBE_MS=15000

# ─── Bull Queue ───────────────────────────────────────
BULL_QUEUE_LIMIT=200
BULL_QUEUE_DURATION_MS=1000
BULL_WORKER_CONCURRENCY=10

# ─── MySQL ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=throttle_db
DB_USERNAME=root
DB_PASSWORD=root
DB_POOL_SIZE=20

# ─── App ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development
