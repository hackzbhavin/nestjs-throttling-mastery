# ─── App ───────────────────────────────────────────────────────────────────────
PORT=3000

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── MySQL ─────────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=throttle_db

# ─── Throttle Core ─────────────────────────────────────────────────────────────
# Max requests per entity per window
THROTTLE_GLOBAL_LIMIT=100

# Token refill rate (tokens per second)
THROTTLE_REFILL_RATE=10

# Sliding window duration in ms (alternative strategy)
THROTTLE_WINDOW_MS=60000

# ─── Multi-Server (2 servers in same DC) ────────────────────────────────────────
# Number of nodes — used to divide limit in LOCAL fallback mode
# LOCAL mode limit per node = THROTTLE_GLOBAL_LIMIT / THROTTLE_NODE_COUNT
THROTTLE_NODE_COUNT=2

# Comma-separated peer URLs for gossip sync in PEER fallback mode
# Server 1 sets this to Server 2's URL and vice versa
# Leave empty for single-node / Docker local dev
THROTTLE_PEER_URLS=http://server-2:3000

# Shared secret for internal peer-sync endpoint (keep out of git!)
THROTTLE_INTERNAL_KEY=change-me-in-production

# ─── Circuit Breaker ───────────────────────────────────────────────────────────
# Redis failures before circuit trips to OPEN
CB_FAILURE_THRESHOLD=3

# Time in ms before OPEN circuit probes Redis again (HALF_OPEN)
CB_RESET_TIMEOUT_MS=10000
